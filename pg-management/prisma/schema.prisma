generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  role      String   @default("STUDENT") // "ADMIN" or "STUDENT"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  studentProfile StudentProfile?
}

model StudentProfile {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  phone     String?
  parentPhone String?
  address   String?
  bloodGroup String?
  
  roomId    String?
  room      Room?    @relation(fields: [roomId], references: [id])
  bedId     String?  @unique
  bed       Bed?     @relation(fields: [bedId], references: [id])

  payments   Payment[]
  complaints Complaint[]
  
  joinedAt   DateTime @default(now())
}

model Room {
  id          String   @id @default(cuid())
  roomNumber  String   @unique
  type        String   // "SINGLE", "DOUBLE", "TRIPLE"
  isAc        Boolean  @default(false)
  pricePerBed Float
  
  beds        Bed[]
  students    StudentProfile[]
}

model Bed {
  id        String   @id @default(cuid())
  bedNumber String   // e.g., "A", "B", "C"
  roomId    String
  room      Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  
  student   StudentProfile?

  @@unique([roomId, bedNumber])
}

model Payment {
  id            String   @id @default(cuid())
  studentId     String
  student       StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  amount        Float
  month         String   // e.g., "2023-10"
  status        String   @default("PENDING") // "PENDING", "PAID"
  paymentDate   DateTime?
  transactionId String?
  
  createdAt     DateTime @default(now())
}

model Complaint {
  id          String   @id @default(cuid())
  studentId   String
  student     StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  title       String
  description String
  status      String   @default("OPEN") // "OPEN", "IN_PROGRESS", "RESOLVED"
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Notice {
  id        String   @id @default(cuid())
  title     String
  content   String
  isActive  Boolean  @default(true)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Gallery {
  id          String   @id @default(cuid())
  imageUrl    String
  category    String   // "ROOM", "BUILDING", "FOOD_AREA"
  description String?
  
  createdAt   DateTime @default(now())
}

model Facility {
  id          String   @id @default(cuid())
  name        String
  icon        String?  // icon name or svg
  description String?
}

model TiffinPlan {
  id          String   @id @default(cuid())
  name        String
  price       Float
  description String
  mealType    String   // "BREAKFAST", "LUNCH", "DINNER", "ALL"
}
